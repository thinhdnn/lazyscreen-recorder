{
  "name": "lazyscreen-recorder",
  "version": "1.0.0",
  "description": "Screen recorder with screen/window/area selection and audio options",
  "main": "src/main/index.js",
  "scripts": {
    "build:vad": "esbuild src/renderer/silero-vad-gate.js --bundle --format=iife --platform=browser --outfile=src/renderer/silero-vad-gate.bundle.js",
    "prestart": "npm run build:vad",
    "postinstall": "npm run build:vad",
    "start": "electron .",
    "dev": "npm run build:vad && electron . --dev",
    "dist": "npm run build:vad && electron-builder",
    "dist:mac": "npm run build:vad && electron-builder --mac",
    "dist:win": "npm run build:vad && electron-builder --win",
    "setup:audiocap": "node scripts/build-audiocap.js",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "build": {
    "appId": "com.lazyscreen.recorder",
    "productName": "LazyScreen Recorder",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "extraResources": [
      {
        "from": "audiocap-bin/${os}",
        "to": "audiocap",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSScreenCaptureUsageDescription": "LazyScreen Recorder needs Screen Recording permission to capture system audio.",
        "NSMicrophoneUsageDescription": "LazyScreen Recorder needs microphone access to capture your voice."
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "fix-webm-metainfo": "^1.0.8",
    "ws": "^8.20.0"
  }
}
